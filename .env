# client
SERVER_ADDR=192.168.0.104
# API_PREFIX=api
PROTOCOL=https

# server
SERVER_PORT=3080

# screenshots
INTERVAL=1000
QUALITY=0.75
QUALITY_WIDTH=1280 #min 640 max 1280
QUALITY_HEIGHT=960 #min 480 max 960

# capture mode
# PHOTO_MODE: auto — фото-режим макс. разрешения (ImageCapture) с фоллбэком; off — только видео-кадр
PHOTO_MODE=auto
# таймаут загрузки снимка, мс (фото крупнее видео-кадра — нужен запас)
UPLOAD_TIMEOUT=20000